{
	"name": "eg-devis-init",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"check-client": "node scripts/check-client.js",
		"screenshots": "node scripts/generate-screenshots.mjs"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{json,md,css,html}": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^25.6.0",
		"@vitest/ui": "^4.1.5",
		"eslint": "^10.2.1",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@tailwindcss/typography": "^0.5.19",
		"@types/leaflet": "^1.9.21",
		"html2canvas": "^1.4.1",
		"jspdf": "^4.2.1",
		"leaflet": "^1.9.4",
		"marked": "^18.0.2",
		"resend": "^6.12.2",
		"zod": "^4.3.6"
	}
}
